{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Item available in the shop",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "rating": { "type": "number" },
        "available": { "type": "boolean" },
        "description": { "type": "string" }
      },
      "required": ["name", "price", "image", "available"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "preparing", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "Customer ratings and comments",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "comment": { "type": "string" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "rating", "createdAt"]
    },
    "Wishlist": {
      "title": "Wishlist",
      "description": "User's saved items",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productIds": { "type": "array" }
      },
      "required": ["userId", "productIds"]
    }
  },
  "firestore": {
    "/products": {
      "schema": "Product",
      "description": "Public list of snacks and drinks"
    },
    "/orders": {
      "schema": "Order",
      "description": "Private customer orders"
    },
    "/feedback": {
      "schema": "Feedback",
      "description": "Public customer reviews"
    },
    "/wishlists/{userId}": {
      "schema": "Wishlist",
      "description": "User-specific wishlist"
    }
  }
}
